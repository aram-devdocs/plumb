# e2e-sites/<framework>/dist/ — generated by `just build` per fixture.
e2e-sites/*/dist/
# Angular leaves a .angular incremental cache.
e2e-sites/*/.angular/
# Next.js writes an `out/` between `next build` and the rename to `dist/`.
e2e-sites/*/out/
# Next.js build cache.
e2e-sites/*/.next/

# mdBook build outputs (book.toml build-dir = "book"; some workflows write to docs/book/).
/book/
/docs/book/
